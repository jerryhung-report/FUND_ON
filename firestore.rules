rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions (The 8 Pillars) ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn(); // Relaxed to allow corporate SSO users
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 256;
    }

    // --- Entity Validations ---

    function isValidHistoryFund(data) {
      return data.keys().hasAll(['code', 'name', 'effectiveDate', 'gmSign'])
        && data.keys().size() >= 4 && data.keys().size() <= 16
        && data.code is string
        && data.name is string
        && data.effectiveDate is string;
    }

    function isValidChecklistItem(data) {
      return data.keys().hasAll(['id', 'completed', 'section', 'task', 'role'])
        && data.keys().size() >= 5 && data.keys().size() <= 10
        && data.id is int
        && data.completed is bool;
    }

    // --- Collection Rules ---

    // Permanent History Storage
    match /history/{fundCode} {
      allow get, list: if isSignedIn();
      
      // Permanently stored: Create allowed only once per ID, no updates or deletes.
      allow create: if isVerified() 
        && isValidId(fundCode) 
        && fundCode == incoming().code
        && isValidHistoryFund(incoming());
      
      allow update, delete: if false;
    }

    // Active Session Checklist State
    match /session_state/checklist/items/{itemId} {
      allow read: if isSignedIn();
      
      allow create, update: if isVerified()
        && isValidId(itemId)
        && isValidChecklistItem(incoming())
        // Ensure atomic updates to specific fields
        && (request.method == 'create' || incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'date', 'updatedBy']));
      
      // Allow clearing items if needed for a new session
      allow delete: if isVerified();
    }
  }
}
