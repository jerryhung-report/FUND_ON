rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions (The 8 Pillars) ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn(); // Relaxed to allow corporate SSO users
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 256;
    }

    // --- Entity Validations ---

    function isValidHistoryFund(data) {
      return data.keys().hasAll(['code', 'name', 'effectiveDate', 'gmSign'])
        && data.keys().size() >= 4 && data.keys().size() <= 16
        && data.code is string
        && data.name is string
        && data.effectiveDate is string;
    }

    function isValidChecklistItem(data) {
      return data.keys().hasAll(['id', 'completed', 'section', 'task', 'role'])
        && data.keys().size() >= 5 && data.keys().size() <= 10
        && data.id is int
        && data.completed is bool;
    }

    // --- Collection Rules ---

    // Permanent History Storage
    match /history/{fundCode} {
      allow read: if isSignedIn();
      // Allow create/update for verified users. 
      // Update is allowed to handle re-archiving or overwriting.
      allow create, update: if isVerified() && isValidId(fundCode);
      allow delete: if false;
    }

    // Active Session Checklist State
    match /session_state/checklist/items/{itemId} {
      allow read: if isSignedIn();
      // Broadened write permission for checklist items to ensure batch operations succeed
      allow write: if isVerified() && isValidId(itemId);
    }
  }
}
